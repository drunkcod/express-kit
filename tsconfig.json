{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["ES2024"],
    "module": "NodeNext",

    "strict": true,
    "declaration": true,
    "outDir": "lib",
    "esModuleInterop": true,
    "rootDir": "./src",
    "baseUrl": "./",
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "exclude": ["node_modules", "lib", "examples", "packages", "**/*.spec.ts"]
}
